# Build output and dependencies
/dist
/tmp
/out-tsc
/bazel-out
/node_modules
/.angular/cache

# Logs and caches
npm-debug.log
yarn-error.log
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# IDE and OS files
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/
.history/*
.DS_Store
Thumbs.db

# Keep only essential project files visible in repository
/*
!/.gitignore
!/.editorconfig
!/.prettierrc
!/README.md
!/netlify.toml
!/package.json
!/package-lock.json
!/angular.json
!/tsconfig.json
!/tsconfig.app.json
!/tsconfig.spec.json
!/scripts/
!/scripts/**
!/public/
!/public/**
!/src/
!/src/**

# Environment configs (keep secrets out of git)
/src/environments/environment*.ts
!/src/environments/environment.example.ts
